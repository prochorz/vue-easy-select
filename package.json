{
  "name": "vue-easy-select",
  "version": "0.1.0",
  "description": "Flexible select component for Vue 3 — composable primitives plus a ready-to-use opinionated select. Single/multiple, searchable, slot-driven, form-friendly.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/assets/index.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "vue",
    "vue3",
    "vue-component",
    "select",
    "dropdown",
    "multiselect",
    "combobox",
    "form",
    "typescript",
    "a11y"
  ],
  "author": "Prokhor Zimon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pzimon/vue-easy-select.git"
  },
  "bugs": {
    "url": "https://github.com/pzimon/vue-easy-select/issues"
  },
  "homepage": "https://github.com/pzimon/vue-easy-select#readme",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.4.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.9",
    "floating-vue": "^2.0.0-beta.20",
    "happy-dom": "^14.12.3",
    "sass": "^1.61.0",
    "typescript": "^4.9.3",
    "vite": "^4.5.3",
    "vite-plugin-dts": "^3.6.0",
    "vite-plugin-lib-inject-css": "^1.3.0",
    "vitepress": "^1.1.3",
    "vitest": "^1.6.1",
    "vue-tsc": "^1.8.19"
  },
  "peerDependencies": {
    "vue": "^3.3.6"
  }
}
